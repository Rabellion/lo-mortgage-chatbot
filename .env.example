# OpenAI — used for RAFT triplet synthesis (GPT-4o)
OPENAI_API_KEY=sk-...

# Hugging Face — model download
HF_TOKEN=hf_...

# Weights & Biases — training experiment tracking
WANDB_API_KEY=...
WANDB_PROJECT=lo-mortgage-chatbot

# Pinecone — vector store
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=lo-mortgage-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Data paths (defaults work, override if needed)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# Chunking
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=5

# RAFT synthesis
SYNTHESIS_MODEL=gpt-4o
SYNTHESIS_CONCURRENCY=30
RAFT_TARGET_TRIPLETS=20000

# Fine-tuning
BASE_MODEL=google/gemma-4-31b-it
LORA_R=16
LORA_ALPHA=32
LEARNING_RATE=2e-4
NUM_EPOCHS=3
